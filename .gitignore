# ============================================================
# 🔒 RECIPEZZ — .gitignore
# ============================================================

# ─── 🔐 SENSITIVE FILES (NEVER COMMIT) ───────────────────────
# main.dart contains Supabase URL + Anon Key.
# Use lib/main.dart.example as the safe reference template.
lib/main.dart

# Environment / secrets files
.env
.env.*
*.env
secrets.dart
lib/secrets.dart
lib/config/secrets.dart
google-services.json
GoogleService-Info.plist
android/key.properties
*.jks
*.keystore

# ─── Flutter / Dart ─────────────────────────────────────────
# Build outputs
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.metadata

# Generated files (Riverpod codegen, mocks, etc.)
*.g.dart
*.freezed.dart
*.mocks.dart
lib/generated_plugin_registrant.dart

# ─── iOS ────────────────────────────────────────────────────
ios/Pods/
ios/.symlinks/
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Runner.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings

# ─── Android ────────────────────────────────────────────────
android/.gradle/
android/captures/
android/local.properties
android/gradle.properties

# ─── macOS ──────────────────────────────────────────────────
macos/Flutter/GeneratedPluginRegistrant.swift
macos/Flutter/ephemeral/
macos/Runner.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings

# ─── Windows ────────────────────────────────────────────────
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake

# ─── Linux ──────────────────────────────────────────────────
linux/flutter/generated_plugin_registrant.cc
linux/flutter/generated_plugin_registrant.h
linux/flutter/generated_plugins.cmake

# ─── IDE / OS ───────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.iml.bak
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ─── Logs & Crash reports ───────────────────────────────────
*.log
crash-*.txt
